# Plebian-OS 0.1.1 — authoritative coordinated release closure.
#
# A named release manifest overrides ambient values for every key it contains.
# The OS tag is resolved only while building; the installed image persists that
# resolved commit, not the movable tag name. Related repositories use full
# commit IDs directly.

PLEBIAN_OS_VERSION=0.1.1
PLEBIAN_OS_RELEASE_MODE=1

# The OS commit is self-referential until the release commit is tagged.
PLEBIAN_OS_REF=v0.1.1
PLEBIAN_OS_REPO=https://github.com/itsmygithubacct/plebian-os.git
PLEBIAN_OS_BRANCH=

# Coordinated related source commits.
PLEB_REF=6978e285f83bac708cd238d5d59da8581bc5ee33
PLEB_REPO=https://github.com/itsmygithubacct/pleb.git
PLEB_BRANCH=
KILIX_REF=85301efc7506486cf499d3655fd402bb4403b27e
KILIX_REPO=https://github.com/itsmygithubacct/kilix.git
KILIX_BRANCH=
KILIX95_REF=d30f8f204a677154602fcd8c996ce96b5d53a092
KILIX95_REPO=https://github.com/itsmygithubacct/kilix-95.git
KILIX95_BRANCH=

# Archived Debian 13.5 installer media plus a verified post-13.6 package
# snapshot. The base installer remains permanently addressable while the
# installed package closure receives the snapshot's current stable fixes.
PLEBIAN_OS_NETINST_URL=https://cdimage.debian.org/cdimage/archive/13.5.0/amd64/iso-cd/debian-13.5.0-amd64-netinst.iso
PLEBIAN_OS_NETINST_SHA256=95838884f5ea6c82421dfe6baaa5a639dbbe6756c1e380f9fe7a7cb0c1949d2a
PLEBIAN_OS_APT_SNAPSHOT=20260712T000000Z

# Verified fallback engine. First boot builds the clickable fork over it.
KILIX_PREBUILT_VERSION=0.47.4
KILIX_PREBUILT_SHA256=bc230142b2bd27f2a4bf1b1b67575f3d397a4ea2cc83f4ac2b912c306a939693
PLEBIAN_OS_BUILD_KILIX_FORK=1

# Exact official Go archives used to build the fork on either supported host
# architecture. Pleb records and verifies their installed source provenance.
PLEBIAN_OS_KILIX_GO_MIN_VERSION=1.26
PLEBIAN_OS_KILIX_GO_VERSION=go1.26.4
PLEBIAN_OS_KILIX_GO_SHA256_AMD64=1153d3d50e0ac764b447adfe05c2bcf08e889d42a02e0fe0259bd47f6733ad7f
PLEBIAN_OS_KILIX_GO_SHA256_ARM64=ef758ae7c6cf9267c9c0ef080b8965f453d89ab2d25d9eb22de4405925238768

# Release desktop contract: use the exact external authoritative provider.
KILIX_DESKTOP_PROVIDER=external
KILIX95_AUTO_INSTALL=1

# Optional remote installer execution stays disabled in the release closure.
PLEBIAN_OS_INSTALL_UV=0
