# Plebian-OS 0.1.0 — shared release pin manifest.
#
# Sourced by build/remaster-iso.sh (and, through it, the Python builders) when
# PLEBIAN_OS_RELEASE=0.1.0 is set, to build a reproducible release image with
# every moving component pinned to the coordinated v0.1.0 tag. Named release
# manifests are authoritative for the keys they contain, so ambient values
# cannot silently weaken a release closure.
#
# Before a real release build, replace every REPLACE_ME (see RELEASING.md). The
# builder refuses release mode while any REPLACE_ME remains, and then fails
# closed if a checksum does not match — a stale placeholder aborts the build
# rather than shipping unverified bits.

PLEBIAN_OS_VERSION=0.1.0
PLEBIAN_OS_RELEASE_MODE=1

# Coordinated source refs — the v0.1.0 tag in each repo.
PLEBIAN_OS_REF=v0.1.0
PLEB_REF=v0.1.0
KILIX_REF=v0.1.0
KILIX95_REF=v0.1.0

# Prebuilt fallback kitty engine (fetched during `pleb install`; the clickable
# fork is then built over it at first boot unless PLEBIAN_OS_BUILD_KILIX_FORK=0).
# Pin the exact upstream kitty release and its .txz sha256.
KILIX_PREBUILT_VERSION=0.47.4
KILIX_PREBUILT_SHA256=bc230142b2bd27f2a4bf1b1b67575f3d397a4ea2cc83f4ac2b912c306a939693

# Pinned Debian netinst — the exact point release this image is validated on.
# sha256sum of the netinst ISO the build must consume (debian-13.5.0-amd64-netinst).
PLEBIAN_OS_NETINST_SHA256=95838884f5ea6c82421dfe6baaa5a639dbbe6756c1e380f9fe7a7cb0c1949d2a

# Optional but recommended for a fully reproducible first-boot apt closure:
# a snapshot.debian.org timestamp, e.g. 20260701T000000Z. Empty = track the
# live mirror (package versions then float at first-boot time).
PLEBIAN_OS_APT_SNAPSHOT=
