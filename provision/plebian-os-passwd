#!/usr/bin/env python3
"""plebian-os-passwd — check / change the invoking user's login password.

Plebian-OS ships a default password ('plebian') so a fresh install is usable
out of the box; the Kilix 95 desktop then prompts the owner to change it. That
desktop runs as the unprivileged owner, which cannot read /etc/shadow — so the
provisioner installs this helper together with a NARROW passwordless sudoers
rule (/etc/sudoers.d/plebian-os-passwd) that allows exactly this one command,
without granting general passwordless sudo:

    sudo plebian-os-passwd check   exit 0 if the user's password IS 'plebian',
                                   1 if it is something else / locked,
                                   2 on error (can't tell)
    sudo plebian-os-passwd set     read ONE line (the new password) from stdin
                                   and set it via chpasswd; refuses empty and
                                   refuses 'plebian'. exit 0 on success.

It only ever operates on the account that invoked sudo ($SUDO_USER) — never
root, never another user — so the narrow grant cannot be turned into a
privilege escalation. The new password is read from stdin, never argv, so it
never appears in `ps`.
"""
import ctypes
import ctypes.util
import os
import subprocess
import sys

DEFAULT_PASSWORD = "plebian"
# Production ALWAYS reads /etc/shadow. PLEBIAN_OS_SHADOW is honored ONLY when the
# helper is unprivileged (euid != 0) — i.e. the test suite calling cmd_check
# directly against a fixture; the real (root, via sudo) path ignores it entirely,
# so the hook can never be turned into an arbitrary-file read even if sudo were
# ever misconfigured to pass the variable through.
SHADOW_PATH = ("/etc/shadow" if os.geteuid() == 0
               else os.environ.get("PLEBIAN_OS_SHADOW", "/etc/shadow"))


def die(msg):
    print(f"plebian-os-passwd: {msg}", file=sys.stderr)
    sys.exit(2)


def target_user():
    user = os.environ.get("SUDO_USER") or ""
    if not user or user == "root":
        die("must be run through sudo as a normal user")
    return user


def shadow_hash(user):
    try:
        with open(SHADOW_PATH) as f:
            for line in f:
                parts = line.split(":")
                if parts and parts[0] == user:
                    return parts[1]
    except OSError as e:
        die(f"cannot read /etc/shadow: {e}")
    die(f"no shadow entry for {user!r}")


def libc_crypt(word, setting):
    """crypt(3) via libcrypt — handles every scheme the shadow file might use
    (yescrypt $y$, sha512 $6$, bcrypt $2b$, …). The stdlib `crypt` module was
    removed in Python 3.13, so bind libcrypt directly."""
    name = ctypes.util.find_library("crypt") or "libcrypt.so.1"
    try:
        lib = ctypes.CDLL(name, use_errno=True)
    except OSError as e:
        die(f"libcrypt unavailable: {e}")
    lib.crypt.restype = ctypes.c_char_p
    lib.crypt.argtypes = (ctypes.c_char_p, ctypes.c_char_p)
    out = lib.crypt(word.encode(), setting.encode())
    return out.decode() if out else None


def cmd_check(user):
    stored = shadow_hash(user)
    # locked / no-login / passwordless entries are, by definition, not 'plebian'
    if not stored or stored[0] in "!*" or stored in ("", "x"):
        return 1
    got = libc_crypt(DEFAULT_PASSWORD, stored)
    if got is None:
        die("crypt() failed on the stored hash")
    return 0 if got == stored else 1


def cmd_set(user):
    new = sys.stdin.readline().rstrip("\n")
    if not new:
        die("empty password refused")
    if new == DEFAULT_PASSWORD:
        die("refusing to set the default password 'plebian'")
    # absolute path so the root helper never depends on PATH resolution
    chpasswd = "/usr/sbin/chpasswd" if os.path.exists("/usr/sbin/chpasswd") else "chpasswd"
    p = subprocess.run([chpasswd], input=f"{user}:{new}\n", text=True,
                       capture_output=True)
    if p.returncode != 0:
        die(f"chpasswd failed: {(p.stderr or p.stdout).strip()}")
    return 0


def main():
    if os.geteuid() != 0:
        die("must run as root (through the sudoers rule)")
    action = sys.argv[1] if len(sys.argv) > 1 else ""
    if action not in ("check", "set"):
        die("usage: plebian-os-passwd check|set")
    user = target_user()
    sys.exit(cmd_check(user) if action == "check" else cmd_set(user))


if __name__ == "__main__":
    main()
